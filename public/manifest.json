{
  "manifest_version": 3,
  "name": "Cooldown Tracker",
  "version": "1.0.0",
  "description": "Controla pausas entre visitas y bloquea sitios durante el cooldown.",
  "permissions": ["alarms", "notifications", "storage", "tabs", "webNavigation"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_title": "Abrir Cooldown Tracker",
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
